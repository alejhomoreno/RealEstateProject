extends ./layout/app

block styles 
    link(rel="stylesheet" href="https://unpkg.com/leaflet@1.8.0/dist/leaflet.css")

block contents
    div(class="py-5")
        h1(class="text-center text-4xl font-extrabold") location on the map

        div(class="flex flex-col md:flex-row items-center py-10 gap-4")
            h2(class="text-sm uppercase text-gray-800 font-bold") Filter by:

            div(class="w-full md:w-auto flex items-center gap-2")
                label(for="tag" class="text-sm w-24 uppercase text-gray-500 font-bold") Tags
                select(id="tag" class="bg-white w-full px-3 py-2 border border-gray-300 rounded-md shadow")
                    option(value="" selected) -- Select a tag --
                    each tag  in tags
                        option(value=tag.id)= tag.name
            
            div(class="w-full md:w-auto flex items-center gap-2")
                label(for="price" class="text-sm w-24 uppercase text-gray-500 font-bold") Prices
                select(id="price" class="bg-white w-full px-3 py-2 border border-gray-300 rounded-md shadow")
                    option(value="" selected) -- Select a price --
                    each price in prices
                        option(value=price.id)= price.name

        div(id="map-home" class="h-[400px] md:h-[500px] w-full md:w-4/5 lg:w-2/3 mx-auto mt-10 rounded-xl shadow-lg border border-gray-200")

        section(class="py-5")
            h2(class="text-center text-4xl font-extrabold pt-10") House and Apartments for sale

            div(class="grid grid-cols-1 lg:grid-cols-3 gap-5 mt-14")
                each house in Houses
                    div(class="bg-white shadow rounded-lg")
                        img(class="object-cover h-72 w-full" src=`/uploads/${house.img}` alt=` image house ${house.title}`)
                        div(class="p-5 space-y-3")
                            h3(class="text-2xl font-bold")= house.title
                            p(class="text-sm text-gray-600") BedRoom: 
                                span(class="font-bold")= house.bedroom
                            p(class="text-sm text-gray-600") WC: 
                                span(class="font-bold")= house.wc
                            p(class="text-sm text-gray-600") Price:  
                                span(class="font-bold")= house.price.name 
                            a(href=`/properties/${house.id}` class="mt-12 block w-full text-center bg-indigo-600 text-white font-bold py-3 uppercase rounded-lg hover:bg-indigo-700 transition duration-300 shadow-md") View Property
                        
        section(class="py-5")
            h2(class="text-center text-4xl font-extrabold pt-10") House and Apartments for sale

            div(class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-5")
                each house in Houses
                    div(class="bg-white shadow rounded-lg")
                        img(class="object-cover h-72 w-full" src=`/uploads/${house.img}` alt=` image house ${house.title}`)
                        div(class="p-5 space-y-3")
                            h3(class="text-2xl font-bold")= house.title
                            p(class="text-sm text-gray-600") BedRoom: 
                                span(class="font-bold")= house.bedroom
                            p(class="text-sm text-gray-600") WC: 
                                span(class="font-bold")= house.wc
                            p(class="text-sm text-gray-600") Price:  
                                span(class="font-bold")= house.price.name 
                            a(href=`/properties/${house.id}` class="mt-12 block w-full text-center bg-indigo-600 text-white font-bold py-3 uppercase rounded-lg hover:bg-indigo-700 transition duration-300 shadow-md") View Property
block scripts 
    script(src="https://unpkg.com/leaflet@1.8.0/dist/leaflet.js")
    script(src="/js/mapaHome.js")           