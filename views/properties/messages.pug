extends ../layout/admin


block contents

    h2(class='text-2xl font-extrabold text-center my-10')= pageName

    a(href="/properties/" class="rounded py-2 px-10 bg-indigo-600 hover:bg-indigo-700 text-sm font-bold text-center text-white uppercase my-5 inline-block w-full md:w-auto") Back to Properties 

    //- pre= JSON.stringify(property , undefined, 2)

    div(class="mx-auto max-w-7xl bg-white shadow")

        if property.messages.length
            ul
                each message in property.messages
                    li(class="border-gray-200 border-b p-4")
                        p(class="font-bold text-gray-800") Name:  
                            span(class="font-normal")= message.customer.name 
                        
                        p(class="font-bold text-gray-800") Email:  
                            span(class="font-normal")= message.customer.email

                        p(class="font-bold text-gray-800") Message: 
                            span(class="font-normal")= message.message

                        p(class="font-bold text-gray-800") Sent at: 
                            span(class="font-normal")= formatDate(message.createdAt)      

            p(class="text-center text-gray-500") Yes, there are messages!
        else 
            p(class="text-center text-gray-500") No messages yet. Please check back later.