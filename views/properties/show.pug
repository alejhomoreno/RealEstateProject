extends ../layout/app

block styles 
    link(rel="stylesheet" href="https://unpkg.com/leaflet@1.8.0/dist/leaflet.css")

block contents
    div(class="py-5")
        h1(class="text-4xl my-10 font-extrabold text-center")= property.title

        // 1. The main flex container wrapping both columns
        div(class="mt-5 md:flex md:gap-4 items-start")
            
            // 2. LEFT COLUMN
            div(class="md:w-2/3") 
                // Moved the tags inside the left column with pb-5 to match the heading on the right
                div(class="pb-5") 
                    a(href="#" class="font-bold text-gray-600 text-sm") Tags: 
                        span(class="font-normal")= property.tag.name 
                
                // Added w-full, rounded corners, and a shadow for a cleaner look
                img(src=`/uploads/${property.img}` alt=`Image of ${property.title}` class="w-full rounded-lg shadow-md")

                div(class="px-5 py-10 space-y-5")
                    p= property.description

                    h2(class="text-2xl leading-6 font-bold text-gray-900") Features

                    div(class="grid grid-cols-1 md:grid-cols-2 gap-4")
                        p(class="text-gray-800 block text-xs") WC: 
                            span(class="font-bold text-gray-900")= property.wc

                        p(class="text-gray-800 block text-xs") BEDROOMS: 
                            span(class="font-bold text-gray-900")= property.bedrooms

                        p(class="text-gray-800 block text-xs") GARAGE: 
                            span(class="font-bold text-gray-900")= property.garage

                        p(class="text-gray-800 block text-xs") PRICE: 
                            span(class="font-bold text-gray-900")= property.price.name

            // 3. RIGHT COLUMN
            div(class="md:w-1/3")
                // Changed "Ubication" to "Location" and replaced py-10 with pb-5
                h3(class="text-center pb-5 leading-6 text-2xl font-bold text-gray-900") Location 

                // Added w-full, rounded corners, and a shadow to match the image style
                div(class="h-96 w-full rounded-lg shadow-md" id="map" data-lat=property.lat data-lng=property.lng)
                
                div(class="py-5")
                    p(class="text-gray-600") Address:
                        span(class="text-gray-800 block text-lg")= property.calle

                    if !isSeller 
                        h3(class="text-2xl text-center my-10 font-extrabold text=gray-900") Contact Information
                        
                        if sented
                            div(class="max-w-md mx-auto my-10")
                                p.bg-green-600.text-white.uppercase.text-xs.text-center.p-2.mb-1.font-bold Your message has been sent successfully!

                        else if user
                            if errors 
                                div(class="max-w-md mx-auto my-10")
                                    each error in errors
                                        p.bg-red-600.text-white.uppercase.text-xs.text-center.p-2.mb-1.font-bold=error.msg
                            form(method="POST")
                                input(type="hidden" name="_csrf" value=csrfToken)

                                div(class="space-y-5")
                                    label(for="message") Message
                                    textarea(name="message" id="message" class="w-full py-2 border border-gray-300 rounded-lg shadow placeholder-gray-400" placeholder ="Write your message here...")

                                    input(type="submit" value="Send Message" class="bg-indigo-600 text-white font-bold uppercase text-sm w-full p-2 cursor-pointer")

                        else
                            div(class="w-full text-center mt-4")
                                p(class="text-gray-700") You need to 
                                    a(href="/auth/login" class="text-indigo-600 font-bold") log in
block scripts 
    script(src="https://unpkg.com/leaflet@1.8.0/dist/leaflet.js")
    script(src="/js/showMap.js")